<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>修改密码 - MyLifeRepo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <style>
    :root {
      --bg-color: #0a0c10;
      --card-bg: #161b22;
      --text-color: #e6edf3;
      --border-color: #30363d;
      --input-bg: #0d1117;
    }
    .light-mode {
      --bg-color: #f6f8fa;
      --card-bg: #ffffff;
      --text-color: #24292f;
      --border-color: #d0d7de;
      --input-bg: #ffffff;
    }
    body { background: var(--bg-color); color: var(--text-color); transition: 0.3s; padding-top: 100px; }
    .password-card { 
      max-width: 400px; margin: auto; background: var(--card-bg); 
      border: 1px solid var(--border-color); border-radius: 12px; padding: 30px; 
    }
    .form-control { 
      background-color: var(--input-bg) !important; 
      color: var(--text-color) !important; 
      border: 1px solid var(--border-color); 
    }
  </style>
</head>
<body>

<div class="password-card shadow">
  <h4 class="mb-4 text-center"><i class="fas fa-key me-2 text-warning"></i>安全设置</h4>
  
  <div class="mb-3">
    <label class="form-label small">新密码</label>
    <input type="password" id="newPass" class="form-control" placeholder="输入新密码">
  </div>
  
  <div class="mb-4">
    <label class="form-label small">确认新密码</label>
    <input type="password" id="confirmPass" class="form-control" placeholder="再次输入新密码">
  </div>

  <button class="btn btn-warning w-100 fw-bold mb-3" onclick="handleUpdatePass()">确认修改</button>
  <a href="index.html" class="btn btn-link w-100 text-muted text-decoration-none">取消并返回</a>
</div>

<script>
  function handleUpdatePass() {
    const p1 = document.getElementById('newPass').value;
    const p2 = document.getElementById('confirmPass').value;
    const user = localStorage.getItem('username') || 'MYJINS';

    if(!p1 || p1.length < 6) return alert('密码长度至少6位');
    if(p1 !== p2) return alert('两次输入的密码不一致');

    localStorage.setItem(`password_${user}`, p1);
    alert('密码已成功修改，请牢记！');
    location.href = 'index.html';
  }

  // 保持主题一致
  if (localStorage.getItem('theme') === 'light') document.body.classList.add('light-mode');
</script>
</body>
</html>
